stdin=serial
stdout=serial,vidconsole
stderr=serial,vidconsole
baudrate=115200

preboot=cls;
	echo SM-P615 uboot1st;
	echo simplefb 0xca000000 1200x2000;
	echo keys: volup=${key_volup} voldown=${key_voldown} power=${key_power};
	if test "${key_voldown}" = "1"; then echo voldown held - dropping to shell; fi;
	echo temp shell only

bootdelay=0
bootcmd=echo ready
