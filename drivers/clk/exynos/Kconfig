config CLK_EXYNOS
	bool
	select CLK
	help
	  This enables support for common clock driver API on Samsung
	  Exynos SoCs.

menu "Clock drivers for Exynos SoCs"
	depends on CLK_EXYNOS

config CLK_EXYNOS7420
	bool "Clock driver for Samsung's Exynos7420 SoC"
	default y
	help
	  This enables common clock driver support for platforms based
	  on Samsung Exynos7420 SoC.

config CLK_EXYNOS7870
	bool "Clock driver for Samsung's Exynos7870 SoC"
	select CLK_CCF
	help
	  This enables common clock driver support for platforms based
	  on Samsung Exynos7870 SoC.

config CLK_EXYNOS850
	bool "Clock driver for Samsung's Exynos850 SoC"
	select CLK_CCF
	help
	  This enables common clock driver support for platforms based
	  on Samsung Exynos850 SoC.

config CLK_EXYNOS9610
	bool "Clock driver for Samsung's Exynos9610 SoC"
	select CLK_CCF
	help
	  Minimal CMU_TOP provider for Samsung Exynos9610-class parts
	  (e.g. SM-P615 / gta4xl) during uboot1st bring-up. Reports the
	  rates S-Boot leaves configured so DM-aware drivers can bind
	  without relying on fixed-clock stubs.

endmenu
